@{
    ViewData["Title"] = "Edit Project";
}

<div class="topbar">
    <h1 class="topbar-title">
        <i class="bi bi-pencil-square"></i> Edit Project
    </h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-pencil-square"></i> Project Details
            </div>
            <div class="card-body" id="projectFormContainer">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading project...</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-people"></i> Project Members
            </div>
            <div class="card-body" id="membersContainer">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3">Loading members...</p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-info-circle"></i> Project Info
            </div>
            <div class="card-body" id="infoContainer">
                <p class="text-muted text-sm">Loading...</p>
            </div>
        </div>
    </div>
</div>

<script>
    const API_BASE_URL = 'http://localhost:5000/api';
    const projectId = new URLSearchParams(window.location.search).get('id');

    document.addEventListener('DOMContentLoaded', function() {
        if (projectId) {
            loadProject();
            loadMembers();
        }
    });

    async function loadProject() {
        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}`, {
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });
            const project = await response.json();

            const container = document.getElementById('projectFormContainer');
            container.innerHTML = `
                <form id="projectForm">
                    <div class="mb-3">
                        <label for="name" class="form-label">Project Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" value="${project.name}" required>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" rows="5">${project.description || ''}</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check"></i> Save Changes
                        </button>
                        <a href="/Project" class="btn btn-secondary">
                            <i class="bi bi-x"></i> Cancel
                        </a>
                    </div>
                </form>
            `;

            document.getElementById('projectForm').addEventListener('submit', saveProject);

            // Load info
            const infoContainer = document.getElementById('infoContainer');
            infoContainer.innerHTML = `
                <div class="mb-3">
                    <small class="text-muted">Created By</small>
                    <p>${project.createdBy}</p>
                </div>
                <div class="mb-3">
                    <small class="text-muted">Created Date</small>
                    <p>${new Date(project.createdDate).toLocaleDateString()}</p>
                </div>
                <div>
                    <button class="btn btn-danger w-100" onclick="deleteProject()">
                        <i class="bi bi-trash"></i> Delete Project
                    </button>
                </div>
            `;
        } catch (error) {
            console.error('Error loading project:', error);
            document.getElementById('projectFormContainer').innerHTML = '<div class="alert alert-danger">Error loading project</div>';
        }
    }

    async function loadMembers() {
        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}/members`, {
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });
            const members = await response.json();

            const container = document.getElementById('membersContainer');

            if (!members || members.length === 0) {
                container.innerHTML = `
                    <p class="text-muted">No members yet</p>
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                        <i class="bi bi-plus"></i> Add Member
                    </button>
                `;
                return;
            }

            container.innerHTML = `
                <div class="list-group">
                    ${members.map(m => `
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">${m.fullName || m.email}</h6>
                                <small class="text-muted">${m.email}</small>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" onclick="removeMember(${m.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    `).join('')}
                </div>
                <button class="btn btn-sm btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#addMemberModal">
                    <i class="bi bi-plus"></i> Add Member
                </button>
            `;
        } catch (error) {
            console.error('Error loading members:', error);
        }
    }

    async function saveProject(e) {
        e.preventDefault();

        const name = document.getElementById('name').value.trim();
        const description = document.getElementById('description').value.trim();

        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}`, {
                method: 'PUT',
                headers: {
                    'Authorization': `Bearer ${getToken()}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    name: name,
                    description: description
                })
            });

            if (response.ok) {
                alert('Project updated successfully!');
                location.reload();
            } else {
                alert('Error updating project');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error updating project');
        }
    }

    async function deleteProject() {
        if (!confirm('Are you sure? This will delete the project and all its tasks.')) return;

        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });

            if (response.ok) {
                alert('Project deleted successfully!');
                window.location.href = '/Project';
            } else {
                alert('Error deleting project');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error deleting project');
        }
    }

    async function removeMember(userId) {
        if (!confirm('Remove this member?')) return;

        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}/members/${userId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });

            if (response.ok) {
                loadMembers();
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }

    function getToken() {
        return localStorage.getItem('authToken') || '';
    }
</script>
