@model TaskManagementWeb.Models.DTO.ProjectDTO
@{
}

<h1 class="mt-3">Edit Project</h1>

<p>
    @if(@Model is not null)
    {
        <form asp-controller="Project" asp-action="Edit" method="post">
            <div class="mb-3">
                <label for="Id" class="form-label>">Project Id</label>
                <input type="text" class="form-control" asp-for="Id" readonly/>
            </div>
            <div class="mb-3">
                <label for="Name" class="form-label>">Project Name</label>
                <input type="text" class="form-control" asp-for="Name" />
            </div>

            <div class="mb-3">
                <label for="Description" class="form-label>">Project Description</label>
                <input type="text" class="form-control" asp-for="Description" />
            </div>
            <div class="mt-3 d-flex justify-content-between">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="submit" class="btn btn-danger" asp-action="Delete">Delete</button>
            </div>
        </form>
    }
</p>
