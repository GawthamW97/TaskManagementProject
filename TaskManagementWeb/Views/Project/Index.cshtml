@model IEnumerable<TaskManagementWeb.Models.DTO.ProjectDTO>
@{
}

<h1 class="mt-3">Projects</h1>

<div class="d-flex justify-content-end">
    <a class="btn btn-secondary" asp-controller="Project" asp-action="Add">
        Add Project
    </a>
</div>

<table class="table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Name</td>
                <td>@project.Description</td>
            </tr>
        }
</table>
