@{
    ViewData["Title"] = "Projects";
}

<div class="topbar">
    <h1 class="topbar-title">
        <i class="bi bi-folder2-open"></i> Projects
    </h1>
    <a href="/Project/Add" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Project
    </a>
</div>

<div class="row" id="projectsContainer">
    <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3">Loading projects...</p>
    </div>
</div>

<script>
    const API_BASE_URL = 'http://localhost:5000/api';

    document.addEventListener('DOMContentLoaded', function() {
        loadProjects();
    });

    async function loadProjects() {
        try {
            const response = await fetch(`${API_BASE_URL}/project`, {
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });
            const projects = await response.json();

            const container = document.getElementById('projectsContainer');

            if (!projects || projects.length === 0) {
                container.innerHTML = `
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <i class="bi bi-inbox" style="font-size: 64px; opacity: 0.3;"></i>
                                <p class="mt-3 text-muted">No projects yet. Create your first project!</p>
                                <a href="/Project/Add" class="btn btn-primary">Create Project</a>
                            </div>
                        </div>
                    </div>
                `;
                return;
            }

            container.innerHTML = projects.map(p => `
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">${p.name}</h5>
                            <p class="card-text text-muted">${(p.description || 'No description').substring(0, 100)}...</p>
                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-person"></i> Created by ${p.createdBy}
                                </small>
                            </div>
                            <div class="btn-group w-100" role="group">
                                <a href="/Project/Details/${p.id}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a href="/Project/Edit/${p.id}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteProject(${p.id})">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } catch (error) {
            console.error('Error loading projects:', error);
            document.getElementById('projectsContainer').innerHTML = '<div class="col-12"><div class="alert alert-danger">Error loading projects</div></div>';
        }
    }

    async function deleteProject(projectId) {
        if (!confirm('Are you sure you want to delete this project?')) return;

        try {
            const response = await fetch(`${API_BASE_URL}/project/${projectId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${getToken()}` }
            });

            if (response.ok) {
                location.reload();
            } else {
                alert('Error deleting project');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error deleting project');
        }
    }

    function getToken() {
        return localStorage.getItem('authToken') || '';
    }
</script>
